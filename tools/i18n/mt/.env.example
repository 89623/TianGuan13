# NovaSector 汉化翻译脚本的环境变量模板。
# 用法：cp tools/i18n/mt/.env.example tools/i18n/mt/.env  然后按需填写。
# .env 已被 .gitignore 忽略（含密钥，不会提交）。i18n-mt.ts 启动时自动加载它；
# shell 里显式设置的同名变量优先（覆盖 .env）。

# ===== 后端：codex（默认，Codex CLI）| claude（Claude Code CLI）| openai（OpenAI 兼容 API）=====
I18N_BACKEND=codex

# ----- openai 后端（HTTP，无需 CLI）-----
# OPENAI_API_KEY=sk-xxxxxxxx
# I18N_OPENAI_MODEL=gpt-4o-mini
# base_url 可指向 OpenAI 兼容服务（DeepSeek / 通义 / 本地 vLLM 等）：
# I18N_OPENAI_BASE_URL=https://api.openai.com/v1
#   DeepSeek 例：  I18N_OPENAI_BASE_URL=https://api.deepseek.com/v1   I18N_OPENAI_MODEL=deepseek-chat

# ----- claude 后端（Claude Code CLI，需已登录）-----
# I18N_CLAUDE_MODEL=

# ----- codex 后端 -----
# I18N_CODEX_MODEL=
# I18N_CODEX_REASONING=low

# ===== 通用 / 优化 =====
# I18N_LOCALE=zh-Hans
# I18N_CONCURRENCY=        # 并发批数：openai 默认 4、agent 默认 1（API 可调大，注意限流）
# I18N_CHUNK=              # 每批条数：openai 默认 400、agent 默认 200
# I18N_NO_REUSE=1          # 关闭「跨命名空间复用」（默认开：别处已译过的英文直接套用、不调模型）
# I18N_MAX_CODEX_CALLS=0   # 本次最多调用数（0 不限）
# I18N_CONTINUE_ON_FAIL=1  # 失败后继续（默认失败即停）
# I18N_FULL_GLOSSARY=1     # 每批发送完整术语表（默认只发本批命中的）
# I18N_CODEX_DELAY_MS=0    # 每次调用间隔毫秒
